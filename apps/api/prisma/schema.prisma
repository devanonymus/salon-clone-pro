generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["app"]
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())

  users                 User[]
  clients               Client[]
  clientTenants         ClientTenant[]
  appointments          Appointment[]
  sales                 Sale[]
  fiscalReceipts        FiscalReceipt[]
  staff                 Staff[]
  inventoryProducts     InventoryProduct[]
  serviceRecipeItems    ServiceRecipeItem[]
  inventoryMovements    InventoryMovement[]
  whatsappConfig        TenantWhatsappConfig?
  whatsappConversations WhatsappConversation[]
  servicePrices         ServicePrice[]
  marketingCards        MarketingCard[]
  marketingCardSales    MarketingCardSale[]
  marketingCardPayments MarketingCardPayment[]
  coachSettings        CoachSettings?
  coachFixedCosts      CoachFixedCost[]
  coachPrebookingResults CoachPrebookingResult[]
  marketingCardTemplate MarketingCardTemplate?

  @@schema("app")
}

model User {
  id       String  @id @default(uuid())
  username String
  pinHash  String
  role     String
  active   Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())

  @@unique([tenantId, username])
  @@schema("app")
}

model Client {
  id    String  @id @default(uuid())
  name  String
  phone String?
  email String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())

  @@schema("app")
}

model ClientGlobal {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  email     String?
  createdAt DateTime @default(now())

  tenants ClientTenant[]
  sales   Sale[]

  @@schema("app")
}

model ClientTenant {
  id             String   @id @default(uuid())
  tenantId       String
  clientGlobalId String
  archived       Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  clientGlobal ClientGlobal  @relation(fields: [clientGlobalId], references: [id])
  appointments Appointment[]

  @@unique([tenantId, clientGlobalId])
  @@schema("app")
}

model Staff {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  role      String   @default("COLLABORATORE")
  color     String   @default("#8b5cf6")
  active          Boolean  @default(true)
  monthlyCost     Float    @default(0)
  productiveHours Float    @default(140)
  monthlyTarget   Float    @default(0)
  createdAt       DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  appointments Appointment[]

  @@schema("app")
}

model Appointment {
  id             String   @id @default(uuid())
  tenantId       String
  clientTenantId String
  staffId        String?
  date           DateTime
  duration       Int
  note           String?
  createdAt      DateTime @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  clientTenant ClientTenant @relation(fields: [clientTenantId], references: [id])
  staff        Staff?       @relation(fields: [staffId], references: [id])
  sale         Sale?

  @@schema("app")
}

model Sale {
  id             String   @id @default(uuid())
  tenantId       String
  clientGlobalId String
  appointmentId  String?  @unique
  total          Float
  paymentMethod  String?
  fiscalStatus   String   @default("NOT_ISSUED")
  createdAt      DateTime @default(now())

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  clientGlobal       ClientGlobal        @relation(fields: [clientGlobalId], references: [id])
  appointment        Appointment?        @relation(fields: [appointmentId], references: [id])
  items              SaleItem[]
  fiscalReceipts     FiscalReceipt[]
  inventoryMovements InventoryMovement[]

  @@schema("app")
}

model SaleItem {
  id       String @id @default(uuid())
  saleId   String
  name     String
  type     String @default("service")
  price    Float
  cost          Float   @default(0)
  technicalCost Float   @default(0)
  laborCost     Float   @default(0)
  duration      Int     @default(0)
  staffId       String?
  quantity      Int     @default(1)

  sale Sale @relation(fields: [saleId], references: [id])

  @@schema("app")
}

model FiscalReceipt {
  id        String   @id @default(uuid())
  tenantId  String
  saleId    String
  status    String   @default("DEMO_PRINTED")
  provider  String   @default("DEMO")
  payload   Json?
  response  Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  sale   Sale   @relation(fields: [saleId], references: [id])

  @@schema("app")
}

model InventoryProduct {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  category    String
  productType String   @default("INTERNAL")
  unit        String   @default("pz")
  stock       Float    @default(0)
  minStock    Float    @default(0)
  cost        Float    @default(0)
  sellPrice   Float    @default(0)
  supplier    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  recipes   ServiceRecipeItem[]
  movements InventoryMovement[]

  @@schema("app")
}

model ServiceRecipeItem {
  id          String @id @default(uuid())
  tenantId    String
  serviceName String
  productId   String
  quantity    Float

  tenant  Tenant           @relation(fields: [tenantId], references: [id])
  product InventoryProduct @relation(fields: [productId], references: [id])

  @@schema("app")
}

model InventoryMovement {
  id             String   @id @default(uuid())
  tenantId       String
  productId      String
  saleId         String?
  reason         String
  movementType   String
  quantityBefore Float
  quantityChange Float
  quantityAfter  Float
  createdAt      DateTime @default(now())

  tenant  Tenant           @relation(fields: [tenantId], references: [id])
  product InventoryProduct @relation(fields: [productId], references: [id])
  sale    Sale?            @relation(fields: [saleId], references: [id])

  @@schema("app")
}

model TenantWhatsappConfig {
  id                   String   @id @default(uuid())
  tenantId             String   @unique
  phoneNumberId        String
  businessAccountId    String?
  accessTokenEncrypted String
  apiVersion           String   @default("v21.0")
  enabled              Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@schema("app")
}

model WhatsappConversation {
  id          String   @id @default(uuid())
  tenantId    String
  phone       String
  name        String?
  lastMessage String?
  lastAt      DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  messages WhatsappMessage[]

  @@unique([tenantId, phone])
  @@schema("app")
}

model WhatsappMessage {
  id             String   @id @default(uuid())
  conversationId String
  direction      String
  phone          String
  text           String
  providerId     String?
  createdAt      DateTime @default(now())

  conversation WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@schema("app")
}

model ServicePrice {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  category  String   @default("Altro")
  duration  Int      @default(30)
  price     Float    @default(0)
  cost      Float    @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@schema("app")
}


model MarketingCard {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  price         Float    @default(0)
  sessionsCount Int      @default(4)
  sessions      Json?
  increaseTotal Float    @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@schema("app")
}


model MarketingCardTemplate {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  logoUrl        String?
  salonName      String   @default("Acquaviva Strategic")
  templateStyle  String   @default("LUXURY_GOLD")
  primaryColor   String   @default("#080808")
  accentColor    String   @default("#d4af37")
  title          String   @default("Il tuo percorso bellezza personalizzato")
  subtitle       String   @default("Una card pensata per mantenere il risultato nel tempo.")
  promiseText    String   @default("Non è una semplice promozione: è un percorso guidato per farti restare sempre in ordine, senza improvvisare.")
  valueText      String   @default("Abbiamo racchiuso servizi, prodotti e bonus in una proposta chiara, comoda e ad alto valore.")
  bonusText      String   @default("I bonus inclusi sono pensati per aumentare il risultato e farti vivere un’esperienza più completa.")
  urgencyText    String   @default("I posti disponibili per questo percorso sono limitati per garantire continuità e qualità.")
  guaranteeText  String   @default("Ti guideremo passo dopo passo nella scelta più adatta ai tuoi capelli.")
  ctaText        String   @default("Blocca oggi il tuo percorso e programma subito le sedute.")
  footerText     String   @default("Card personale, non convertibile in denaro.")
  signature      String   @default("Il tuo salone di fiducia")
  promoMessageTemplate   String   @default("Ciao {nome_cliente} 💛\n\nAbbiamo preparato una proposta speciale pensata per mantenere il risultato nel tempo:\n*{nome_card}*\n\nPrezzo card: € {prezzo_card}\nSedute incluse: {sedute}\nPrezzo medio per seduta: € {prezzo_seduta}\n\nVuoi che ti blocchiamo questa possibilità?\n\n{firma}")
  confirmMessageTemplate String   @default("Ciao {nome_cliente} 💛\n\nTi confermiamo la tua card:\n*{nome_card}*\n\nPrezzo card: € {prezzo_card}\nSedute incluse: {sedute}\nPrezzo medio per seduta: € {prezzo_seduta}\n\nTi aspettiamo in salone.\n\n{firma}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@schema("app")
}


model MarketingCardSale {
  id              String   @id @default(uuid())
  tenantId        String
  clientTenantId  String?
  clientName      String
  whatsapp        String?
  cardName        String
  price           Float    @default(0)
  used            Int      @default(0)
  total           Int      @default(1)
  sessions        Json?
  appointments    Json?
  paymentMode     String   @default("RATE_SEDUTE")
  active          Boolean  @default(true)
  payments        MarketingCardPayment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@schema("app")
}


model MarketingCardPayment {
  id                  String   @id @default(uuid())
  tenantId            String
  marketingCardSaleId String
  amount              Float
  paymentType         String   @default("RATA_SEDUTA")
  method              String   @default("CONTANTI")
  note                String?
  paidAt              DateTime @default(now())
  createdAt           DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  sale   MarketingCardSale @relation(fields: [marketingCardSaleId], references: [id])

  @@schema("app")
}

model CoachSettings {
  id                      String   @id @default(uuid())
  tenantId                String   @unique
  vatServicesPercent       Float    @default(22)
  vatResalePercent         Float    @default(22)
  posFeePercent            Float    @default(1.5)
  posFixedFee              Float    @default(0)
  variableOverheadPercent  Float    @default(3)
  taxReservePercent        Float    @default(25)
  productiveHoursMonth     Float    @default(140)
  agendaGridMinutes        Int      @default(5)
  cardGiftKitInCost        Boolean  @default(false)
  allowedDomains           String   @default("")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@schema("app")
}

model CoachFixedCost {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  amount    Float    @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@schema("app")
}

model CoachPrebookingResult {
  id            String   @id @default(uuid())
  tenantId      String
  appointmentId String
  dateKey       String
  clientName    String
  clientPhone   String?
  serviceName   String?
  status        String   @default("NON_PROPOSTO")
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, appointmentId])
  @@schema("app")
}
