generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["app"]
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())

  users                 User[]
  clients               Client[]
  clientTenants         ClientTenant[]
  appointments          Appointment[]
  sales                 Sale[]
  fiscalReceipts        FiscalReceipt[]
  staff                 Staff[]
  inventoryProducts     InventoryProduct[]
  serviceRecipeItems    ServiceRecipeItem[]
  inventoryMovements    InventoryMovement[]
  whatsappConfig        TenantWhatsappConfig?
  whatsappConversations WhatsappConversation[]
  servicePrices         ServicePrice[]

  @@schema("app")
}

model User {
  id       String  @id @default(uuid())
  username String
  pinHash  String
  role     String
  active   Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())

  @@unique([tenantId, username])
  @@schema("app")
}

model Client {
  id    String  @id @default(uuid())
  name  String
  phone String?
  email String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())

  @@schema("app")
}

model ClientGlobal {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  email     String?
  createdAt DateTime @default(now())

  tenants ClientTenant[]
  sales   Sale[]

  @@schema("app")
}

model ClientTenant {
  id             String   @id @default(uuid())
  tenantId       String
  clientGlobalId String
  notes          String?
  createdAt      DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  clientGlobal ClientGlobal  @relation(fields: [clientGlobalId], references: [id])
  appointments Appointment[]

  @@unique([tenantId, clientGlobalId])
  @@schema("app")
}

model Staff {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  role      String   @default("COLLABORATORE")
  color     String   @default("#8b5cf6")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  appointments Appointment[]

  @@schema("app")
}

model Appointment {
  id             String   @id @default(uuid())
  tenantId       String
  clientTenantId String
  staffId        String?
  date           DateTime
  duration       Int
  note           String?
  createdAt      DateTime @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  clientTenant ClientTenant @relation(fields: [clientTenantId], references: [id])
  staff        Staff?       @relation(fields: [staffId], references: [id])
  sale         Sale?

  @@schema("app")
}

model Sale {
  id             String   @id @default(uuid())
  tenantId       String
  clientGlobalId String
  appointmentId  String?  @unique
  total          Float
  paymentMethod  String?
  fiscalStatus   String   @default("NOT_ISSUED")
  createdAt      DateTime @default(now())

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  clientGlobal       ClientGlobal        @relation(fields: [clientGlobalId], references: [id])
  appointment        Appointment?        @relation(fields: [appointmentId], references: [id])
  items              SaleItem[]
  fiscalReceipts     FiscalReceipt[]
  inventoryMovements InventoryMovement[]

  @@schema("app")
}

model SaleItem {
  id       String @id @default(uuid())
  saleId   String
  name     String
  type     String @default("service")
  price    Float
  cost     Float  @default(0)
  quantity Int    @default(1)

  sale Sale @relation(fields: [saleId], references: [id])

  @@schema("app")
}

model FiscalReceipt {
  id        String   @id @default(uuid())
  tenantId  String
  saleId    String
  status    String   @default("DEMO_PRINTED")
  provider  String   @default("DEMO")
  payload   Json?
  response  Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  sale   Sale   @relation(fields: [saleId], references: [id])

  @@schema("app")
}

model InventoryProduct {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  category    String
  productType String   @default("INTERNAL")
  unit        String   @default("pz")
  stock       Float    @default(0)
  minStock    Float    @default(0)
  cost        Float    @default(0)
  sellPrice   Float    @default(0)
  supplier    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  recipes   ServiceRecipeItem[]
  movements InventoryMovement[]

  @@schema("app")
}

model ServiceRecipeItem {
  id          String @id @default(uuid())
  tenantId    String
  serviceName String
  productId   String
  quantity    Float

  tenant  Tenant           @relation(fields: [tenantId], references: [id])
  product InventoryProduct @relation(fields: [productId], references: [id])

  @@schema("app")
}

model InventoryMovement {
  id             String   @id @default(uuid())
  tenantId       String
  productId      String
  saleId         String?
  reason         String
  movementType   String
  quantityBefore Float
  quantityChange Float
  quantityAfter  Float
  createdAt      DateTime @default(now())

  tenant  Tenant           @relation(fields: [tenantId], references: [id])
  product InventoryProduct @relation(fields: [productId], references: [id])
  sale    Sale?            @relation(fields: [saleId], references: [id])

  @@schema("app")
}

model TenantWhatsappConfig {
  id                   String   @id @default(uuid())
  tenantId             String   @unique
  phoneNumberId        String
  businessAccountId    String?
  accessTokenEncrypted String
  apiVersion           String   @default("v21.0")
  enabled              Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@schema("app")
}

model WhatsappConversation {
  id          String   @id @default(uuid())
  tenantId    String
  phone       String
  name        String?
  lastMessage String?
  lastAt      DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  messages WhatsappMessage[]

  @@unique([tenantId, phone])
  @@schema("app")
}

model WhatsappMessage {
  id             String   @id @default(uuid())
  conversationId String
  direction      String
  phone          String
  text           String
  providerId     String?
  createdAt      DateTime @default(now())

  conversation WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@schema("app")
}

model ServicePrice {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  category  String   @default("Altro")
  duration  Int      @default(30)
  price     Float    @default(0)
  cost      Float    @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@schema("app")
}
